{
  "name": "bhadhara-transport-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Desktop wrapper for Bhadhara Transport Management System",
  "author": "Nelson Bhadhara",
  "scripts": {
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.bhadharatransport.app",
    "productName": "Bhadhara Transport",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "main.js",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
